rules_version = '2';

// AI Form & Vault — every user can read and write only their own subtree.
// The vault payload stored here is client-side-encrypted (AES-256-GCM under
// a passphrase only the user holds), so even a rules misconfiguration can't
// expose plaintext. Rules still lock access to the owner as defense in depth.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
